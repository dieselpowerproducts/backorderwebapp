{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "server/**"
    },
    "api/cron/catalog-full-sync.js": {
      "includeFiles": "server/**",
      "maxDuration": 60
    },
    "api/cron/auto-inventory.js": {
      "includeFiles": "server/**",
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/catalog-full-sync",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/auto-inventory",
      "schedule": "0 * * * *"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(auth|backorders|status|email|import|notes|notifications|products|shopify|users|vendors)(.*)",
      "dest": "api/index.js"
    }
  ]
}
